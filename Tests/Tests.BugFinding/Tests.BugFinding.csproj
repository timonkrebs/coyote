<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Tests for bug finding.</Description>
    <AssemblyName>Microsoft.Coyote.Tests.BugFinding</AssemblyName>
    <RootNamespace>Microsoft.Coyote.BugFinding.Tests</RootNamespace>
    <OutputPath>.\bin\</OutputPath>
    <OutputType>Exe</OutputType>
    <NetStandard2Supported>false</NetStandard2Supported>
    <Framework462Supported>false</Framework462Supported>
    <Framework472Supported>true</Framework472Supported>
    <Net8Supported>false</Net8Supported>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn),1591,1998,xUnit1030,xUnit1031,xUnit1051</NoWarn>
  </PropertyGroup>
  <Import Project="..\..\Common\build.props" />
  <Import Project="..\..\Common\key.props" />
  <ItemGroup>
    <ProjectReference Include="..\Tests.Common\Tests.Common.csproj" />
    <ProjectReference Include="..\..\Tools\Coyote\Coyote.csproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5" />
  </ItemGroup>
  <ItemGroup>
    <None Update="xunit.runner.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  <PropertyGroup>
    <!-- The coyote CLI has no net472 build; the net462 tool rewrites those test assemblies. -->
    <CoyoteToolFramework>$(TargetFramework)</CoyoteToolFramework>
    <CoyoteToolFramework Condition="'$(TargetFramework)'=='net472'">net462</CoyoteToolFramework>
  </PropertyGroup>
  <Target Name="CoyoteRewriteWin" AfterTargets="AfterBuild" Condition="'$(OS)'=='Windows_NT'">
    <Exec Command="..\..\bin\$(CoyoteToolFramework)\coyote.exe rewrite $(OutputPath)$(AssemblyName)$(TargetExt) --dump-il-diff --assert-data-races" />
  </Target>
  <Target Name="CoyoteRewriteUnix" AfterTargets="AfterBuild" Condition="'$(OS)'!='Windows_NT'">
    <Exec Command="dotnet ../../bin/$(CoyoteToolFramework)/coyote.dll rewrite $(OutputPath)$(AssemblyName)$(TargetExt) --dump-il-diff --assert-data-races" />
  </Target>
</Project>